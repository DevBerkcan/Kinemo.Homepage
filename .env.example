# SMTP server used by the contact, demo and booking forms.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=website@example.com
SMTP_PASS=replace-me

# Optional sender address. Defaults to "Kinemo Website" <SMTP_USER>.
SMTP_FROM="Kinemo Website <website@example.com>"

# Recipient for incoming website requests.
MAIL_TO=contact@kinemo.de

# Optional comma-separated additional origins, for example a preview domain.
ALLOWED_ORIGINS=https://www.kinemo.de

# Optional analytics. Microsoft Clarity is loaded only after explicit consent.
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Publication gates for repository content that requires documented approval.
# Leave disabled until names, quotes, case studies and metrics are verified.
REFERENCE_CONTENT_APPROVED=false
KINEMO_METRICS_APPROVED=false
